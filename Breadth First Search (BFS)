#include <stdio.h>

int main()
{
    int graph[3][3], visited[3]={0};
    int queue[10], front=0, rear=0;
    int i,j,start;

    printf("Enter adjacency matrix:\n");

    for(i=0;i<3;i++)
        for(j=0;j<3;j++)
            scanf("%d",&graph[i][j]);

    printf("Enter starting vertex (0-2): ");
    scanf("%d",&start);

    queue[rear++]=start;
    visited[start]=1;

    printf("BFS Traversal: ");

    while(front<rear)
    {
        int node=queue[front++];
        printf("%d ",node);

        for(i=0;i<3;i++)
        {
            if(graph[node][i]==1 && !visited[i])
            {
                visited[i]=1;
                queue[rear++]=i;
            }
        }
    }

    return 0;
}
