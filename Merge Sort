#include <stdio.h>

void merge(int a[], int l, int m, int r)
{
    int i=l,j=m+1,k,temp[100];

    for(k=l;i<=m && j<=r;k++)
    {
        if(a[i]<a[j])
            temp[k]=a[i++];
        else
            temp[k]=a[j++];
    }

    while(i<=m) temp[k++]=a[i++];
    while(j<=r) temp[k++]=a[j++];

    for(i=l;i<k;i++)
        a[i]=temp[i];
}

void mergesort(int a[],int l,int r)
{
    int m;

    if(l<r)
    {
        m=(l+r)/2;
        mergesort(a,l,m);
        mergesort(a,m+1,r);
        merge(a,l,m,r);
    }
}

int main()
{
    int a[100],n,i;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    mergesort(a,0,n-1);

    for(i=0;i<n;i++)
        printf("%d ",a[i]);

    return 0;
}
