#include <stdio.h>

int main() {
    int a[100],n,i,pos,item;

    printf("Enter size: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    printf("Insert element and position: ");
    scanf("%d%d",&item,&pos);

    for(i=n;i>=pos;i--)
        a[i]=a[i-1];

    a[pos-1]=item;
    n++;

    printf("Array after insertion:\n");
    for(i=0;i<n;i++)
        printf("%d ",a[i]);

    printf("\nDelete position: ");
    scanf("%d",&pos);

    for(i=pos-1;i<n-1;i++)
        a[i]=a[i+1];

    n--;

    printf("\nArray after deletion:\n");
    for(i=0;i<n;i++)
        printf("%d ",a[i]);
}
