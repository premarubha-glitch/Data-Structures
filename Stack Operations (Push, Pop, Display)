#include <stdio.h>

#define MAX 5

int stack[MAX];
int top = -1;

void push(int item)
{
    if(top == MAX - 1)
        printf("Stack Overflow\n");
    else
        stack[++top] = item;
}

void pop()
{
    if(top == -1)
        printf("Stack Underflow\n");
    else
        printf("Deleted Element = %d\n", stack[top--]);
}

void display()
{
    int i;

    if(top == -1)
        printf("Stack Empty\n");
    else
    {
        printf("Stack Elements: ");
        for(i = top; i >= 0; i--)
            printf("%d ", stack[i]);
    }
}

int main()
{
    push(10);
    push(20);
    push(30);

    display();
    printf("\n");

    pop();

    display();

    return 0;
}
