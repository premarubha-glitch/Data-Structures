#include <stdio.h>

int graph[3][3], visited[3];

void dfs(int v)
{
    int i;

    visited[v]=1;
    printf("%d ",v);

    for(i=0;i<3;i++)
    {
        if(graph[v][i]==1 && visited[i]==0)
            dfs(i);
    }
}

int main()
{
    int i,j,start;

    printf("Enter adjacency matrix:\n");

    for(i=0;i<3;i++)
        for(j=0;j<3;j++)
            scanf("%d",&graph[i][j]);

    printf("Enter starting vertex (0-2): ");
    scanf("%d",&start);

    printf("DFS Traversal: ");

    dfs(start);

    return 0;
}
